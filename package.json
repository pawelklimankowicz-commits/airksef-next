{
  "name": "airksef-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:remote": "playwright test",
    "verify": "npm run lint && npm run test && npm run build && playwright test",
    "postinstall": "prisma generate",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:setup": "npm run db:up && npx prisma db push",
    "stripe:bootstrap": "node scripts/stripe-bootstrap.mjs",
    "gen:uber-sample": "npx tsx scripts/gen-uber-sample.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.8",
    "@prisma/client": "5.22.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
