# Skopiuj do .env.local (nie commituj .env.local).

# PostgreSQL — np. Neon, Supabase, Railway
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Ścieżki stron logowania/rejestracji (zalecane przy app/sign-in i app/sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe — https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_BUSINESS_PRICE_ID=price_yyy

# Resend (opcjonalnie — powiadomienia e-mail)
RESEND_API_KEY=

# Szyfrowanie tokenu KSeF (AES-256): openssl rand -hex 32
KSEF_ENCRYPTION_KEY=

# Opcjonalnie: własny endpoint wysyłki XML (bez tego /ksef działa w trybie symulacji)
KSEF_SUBMIT_URL=
KSEF_ACCESS_TOKEN=

# Publiczny URL (redirecty Stripe, Clerk)
NEXT_PUBLIC_APP_URL=http://localhost:3000
