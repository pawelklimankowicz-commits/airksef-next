generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

model User {
  id                     String    @id @default(cuid())
  clerkId                String    @unique
  email                  String?
  plan                   Plan      @default(FREE)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?
  stripePriceId          String?
  subscriptionStatus     String?
  /// Dane sprzedawcy (Podmiot2 w FA(3)) — zapisywane przez użytkownika w ustawieniach
  sellerNip              String?
  sellerName             String?
  sellerAddress          String?
  sellerCity             String?
  sellerZip              String?
  /// Token autoryzacyjny KSeF (zaszyfrowany AES-256-GCM, klucz KSEF_ENCRYPTION_KEY)
  ksefTokenEncrypted     String?
  /// Środowisko KSeF: "test" = ksef-test.mf.gov.pl, "prod" = ksef.mf.gov.pl
  ksefEnvironment        String?   @default("test")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  invoices               Invoice[]
}

model Invoice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  xmlContent String   @db.Text
  payload    Json
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}
